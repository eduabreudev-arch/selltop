# -------------------------

# ENVIRONMENT

# -------------------------

# Ambiente: development | production

FLASK_ENV=development

# -------------------------

# SECURITY

# -------------------------

# Chave secreta da aplicação (gere com: python -c "import secrets; print(secrets.token_hex(32))")

SECRET_KEY=your-secret-key-here

# -------------------------

# APP

# -------------------------

# URL base da aplicação (ex: http://localhost:5000)

BASE_URL=http://localhost:5000

# -------------------------

# DATABASE (Turso / LibSQL)

# -------------------------

# Nome lógico do banco (opcional dependendo da sua config)

DATABASE=app_db

# URL do banco Turso (ex: libsql://seu-db.turso.io)

TURSO_URL=libsql://your-database.turso.io

# Token de autenticação do Turso

TURSO_AUTH_TOKEN=your-turso-auth-token

# -------------------------

# EMAIL (Yahoo SMTP)

# -------------------------

MAIL_SERVER=smtp.mail.yahoo.com
MAIL_PORT=587
MAIL_USERNAME=[your_email@yahoo.com](mailto:your_email@yahoo.com)
MAIL_FROM=[your_email@yahoo.com](mailto:your_email@yahoo.com)
MAIL_PASSWORD=your_app_password
MAIL_USE_TLS=True
MAIL_USE_SSL=False